{
  "name": "betcyclingfriends",
  "private": true,
  "scripts": {
    "dev": "docker compose -f docker-compose.dev.yml up -d && turbo dev",
    "dev:infra": "docker compose -f docker-compose.dev.yml up -d",
    "dev:infra:down": "docker compose -f docker-compose.dev.yml down",
    "build": "turbo build",
    "test": "turbo test",
    "lint": "turbo lint",
    "migrate": "pnpm --filter @bcf/api exec node ace migration:run",
    "docker:up": "docker compose up --build",
    "docker:down": "docker compose down"
  },
  "packageManager": "pnpm@9.15.9",
  "devDependencies": {
    "turbo": "^2.0.0",
    "typescript": "^5.4.0"
  }
}